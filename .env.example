# ============================================================================
# ADEPT configuration — copy to ".env" and fill in for your homelab.
#   cp .env.example .env
#
# Settings are loaded by adept/config/settings.py (pydantic-settings).
# Nested settings use a double-underscore delimiter, e.g. ADEPT_ELK__URL.
# NEVER commit your real .env (it is git-ignored).
# ============================================================================

# ---- Application ----------------------------------------------------------
ADEPT_ENV=dev                       # dev | prod (prod requires ADEPT_MCP__AUTH_TOKEN)
ADEPT_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
ADEPT_LOG_JSON=true                 # true = structured JSON logs (recommended)
ADEPT_DATA_DIR=./data               # runtime data (db, cache, chroma, audit)

# ---- MCP server (runs on the homelab MCP VM) ------------------------------
ADEPT_MCP__HOST=127.0.0.1           # bind address; set to the Tailscale IP (or 0.0.0.0) for remote agents
ADEPT_MCP__PORT=8765
ADEPT_MCP__PATH=/mcp
ADEPT_MCP__TRANSPORT=streamable-http
# Shared bearer token the agent must present. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ADEPT_MCP__AUTH_TOKEN=CHANGE_ME_generate_a_long_random_token
# Public URL the agent uses to reach this server over the Tailscale tunnel:
ADEPT_MCP__PUBLIC_URL=http://mcp-vm.your-tailnet.ts.net:8765/mcp

# ---- Ollama (LLM + embeddings) --------------------------------------------
# Decoupled on purpose: point at localhost now, a beefier box after upgrade.
ADEPT_OLLAMA__BASE_URL=http://localhost:11434
ADEPT_OLLAMA__MODEL=qwen2.5:7b-instruct   # strong open tool-calling model
ADEPT_OLLAMA__EMBED_MODEL=nomic-embed-text
ADEPT_OLLAMA__TEMPERATURE=0.1
ADEPT_OLLAMA__NUM_CTX=8192
ADEPT_OLLAMA__REQUEST_TIMEOUT=180

# ---- Elasticsearch / ELK (PRIMARY SIEM) -----------------------------------
ADEPT_ELK__ENABLED=true
ADEPT_ELK__URL=https://elk.lab:9200
# Prefer an API key (least privilege) over username/password.
ADEPT_ELK__API_KEY=
ADEPT_ELK__USERNAME=
ADEPT_ELK__PASSWORD=
ADEPT_ELK__VERIFY_CERTS=true
ADEPT_ELK__CA_CERT=                 # path to CA bundle if using a private CA
ADEPT_ELK__DEFAULT_INDEX=logs-*
# Kibana base URL for the Detection Engine deploy path (leave blank to disable deploy).
ADEPT_ELK__KIBANA_URL=https://elk.lab:5601
# Index pattern that holds detection-engine alerts (for siem_list_alerts).
ADEPT_ELK__ALERTS_INDEX=.alerts-security.alerts-*

# ---- Wazuh Indexer (OpenSearch) -------------------------------------------
ADEPT_OPENSEARCH__ENABLED=false
ADEPT_OPENSEARCH__URL=https://wazuh.lab:9200
ADEPT_OPENSEARCH__USERNAME=admin
ADEPT_OPENSEARCH__PASSWORD=
ADEPT_OPENSEARCH__VERIFY_CERTS=true
ADEPT_OPENSEARCH__CA_CERT=
ADEPT_OPENSEARCH__DEFAULT_INDEX=wazuh-alerts-*

# ---- Splunk ----------------------------------------------------------------
ADEPT_SPLUNK__ENABLED=false
ADEPT_SPLUNK__HOST=splunk.lab
ADEPT_SPLUNK__PORT=8089
ADEPT_SPLUNK__USERNAME=
ADEPT_SPLUNK__PASSWORD=
ADEPT_SPLUNK__TOKEN=                # bearer token (alternative to user/pass)
ADEPT_SPLUNK__SCHEME=https
ADEPT_SPLUNK__VERIFY=true
ADEPT_SPLUNK__DEFAULT_INDEX=main

# ---- Sigma rules git repository -------------------------------------------
ADEPT_SIGMA__PATH=./sigma_rules
ADEPT_SIGMA__DEFAULT_BRANCH=main
ADEPT_SIGMA__PROTECTED_BRANCHES=main,release   # commits here require approval
ADEPT_SIGMA__REMOTE=                # optional git remote URL (Gitea/GitHub)

# ---- Threat intelligence ---------------------------------------------------
ADEPT_INTEL__NVD_API_KEY=           # optional; raises NVD rate limits
ADEPT_INTEL__ATTACK_VERSION=        # blank = latest MITRE ATT&CK release
# Comma-separated RSS feeds for recent-attack research:
ADEPT_INTEL__RSS_FEEDS=https://www.cisa.gov/cybersecurity-advisories/all.xml,https://feeds.feedburner.com/TheHackersNews
# SSRF allowlist: only these domains may be fetched by intel/RSS tools.
ADEPT_INTEL__ALLOWED_DOMAINS=services.nvd.nist.gov,www.cisa.gov,raw.githubusercontent.com,feeds.feedburner.com
# Advanced (sensible defaults shown; uncomment to override):
# ADEPT_INTEL__NVD_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
# ADEPT_INTEL__KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
# ADEPT_INTEL__ATTACK_STIX_URL=https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/enterprise-attack/enterprise-attack.json
# ADEPT_INTEL__CACHE_TTL_SECONDS=21600         # CVE/KEV/news cache lifetime (6h)
# ADEPT_INTEL__ATTACK_CACHE_TTL_SECONDS=604800 # ATT&CK STIX bundle cache lifetime (7d)
# ADEPT_INTEL__NVD_RATE_PER_MINUTE=10          # client-side NVD throttle

# ---- ATT&CK coverage + optional DeTT&CT ------------------------------------
# ADEPT_COVERAGE__BASELINE_LOOKBACK_DAYS=7     # default window for field baselines
# DeTT&CT (GPL-3.0) is OPTIONAL and run only as an external process, never
# imported. Leave disabled unless you have a local DeTT&CT checkout.
ADEPT_COVERAGE__DETTECT_ENABLED=false
# Path to the DeTT&CT 'dettect.py' script (preferred) or a 'dettect' executable:
ADEPT_COVERAGE__DETTECT_COMMAND=    # e.g. /opt/DeTTECT/dettect.py
# ADEPT_COVERAGE__DETTECT_PYTHON=             # interpreter to run dettect.py (default: current)
# ADEPT_COVERAGE__DETTECT_TIMEOUT_SECONDS=180

# ---- Knowledge base (RAG) --------------------------------------------------
ADEPT_KB__PERSIST_DIR=./data/chroma
ADEPT_KB__COLLECTION=adept-knowledge
ADEPT_KB__EMBED_MODEL=nomic-embed-text     # Ollama embedding model (must be pulled)
# Chunking / batching (sensible defaults; uncomment to override):
# ADEPT_KB__CHUNK_CHARS=1200
# ADEPT_KB__CHUNK_OVERLAP=150
# ADEPT_KB__BATCH_SIZE=64
# ADEPT_KB__MAX_RESULTS=5
# Optional SigmaHQ community-rule ingestion (best-effort, opt-in):
ADEPT_KB__SIGMAHQ_PATH=             # path to a local SigmaHQ/sigma clone (preferred)
# ADEPT_KB__SIGMAHQ_CLONE=false              # clone on demand from the remote below
# ADEPT_KB__SIGMAHQ_REMOTE=https://github.com/SigmaHQ/sigma.git
# ADEPT_KB__SIGMAHQ_CLONE_TIMEOUT_SECONDS=600

# ---- Notifications (approval requests + deploy events) --------------------
ADEPT_NOTIFY__BACKEND=none          # none | ntfy | discord | slack | webhook
ADEPT_NOTIFY__URL=                  # webhook / ntfy server URL
ADEPT_NOTIFY__TOPIC=                # ntfy topic
ADEPT_NOTIFY__TOKEN=                # bearer/auth token if required

# ---- Attack simulation (Atomic Red Team + Caldera) ------------------------
# Safety defaults: Atomic is propose-only (ADEPT never runs atomics); Caldera
# operations are launched only behind the agent's human-approval gate.
ADEPT_ATTACK__REQUIRE_APPROVAL=true
ADEPT_ATTACK__DRY_RUN_DEFAULT=true
ADEPT_ATTACK__ATOMIC_ENABLED=false
# Local clone of redcanaryco/atomic-red-team (atomics live under <path>/atomics):
ADEPT_ATTACK__ATOMIC_PATH=
# Whitelist of Atomic test technique IDs the system is even allowed to propose:
ADEPT_ATTACK__ATOMIC_ALLOWED_TESTS=T1059.001,T1003.001,T1547.001
ADEPT_ATTACK__CALDERA_ENABLED=false
ADEPT_ATTACK__CALDERA_URL=
ADEPT_ATTACK__CALDERA_API_KEY=
# Header Caldera expects the API key in (server default is "KEY"):
ADEPT_ATTACK__CALDERA_API_KEY_HEADER=KEY
# Deployment-specific ids used when creating an operation (tune per server):
ADEPT_ATTACK__CALDERA_PLANNER_ID=atomic
ADEPT_ATTACK__CALDERA_SOURCE_ID=basic
ADEPT_ATTACK__CALDERA_DEFAULT_GROUP=
ADEPT_ATTACK__CALDERA_TIMEOUT_SECONDS=30

# ---- Agent (runs next to Ollama; connects to MCP over the tunnel) ---------
ADEPT_AGENT__MCP_URL=http://mcp-vm.your-tailnet.ts.net:8765/mcp
ADEPT_AGENT__MCP_TOKEN=CHANGE_ME_same_as_ADEPT_MCP__AUTH_TOKEN
ADEPT_AGENT__MCP_TIMEOUT_SECONDS=30
# Optional override for the chat model (blank = reuse ADEPT_OLLAMA__MODEL):
ADEPT_AGENT__MODEL=
ADEPT_AGENT__CHECKPOINT_DB=./data/agent_history.sqlite
ADEPT_AGENT__AUDIT_LOG=./data/agent_audit.jsonl
ADEPT_AGENT__RECURSION_LIMIT=50
# Tools that require human approval before they run (comma-separated).
ADEPT_AGENT__DANGEROUS_TOOLS=siem_deploy_rule,siem_disable_rule,siem_delete_rule,run_caldera_operation,stop_caldera_operation
# Editor for the approval "edit" action (blank = $VISUAL / $EDITOR / nano):
ADEPT_AGENT__EDITOR=
# ---- Output guardrails (deterministic self-review; both on by default) -----
# LINT_ENABLED refuses illegal tool inputs (e.g. SPL piping into `| delete`,
# leading-wildcard Lucene, malformed Sigma) at submission, before the tool runs.
ADEPT_AGENT__LINT_ENABLED=true
# EVAL_ENABLED inserts an evaluator/critic node that lints each specialist's
# output and bounces it back for regeneration (up to EVAL_MAX_RETRIES) before
# escalating to you.
ADEPT_AGENT__EVAL_ENABLED=true
ADEPT_AGENT__EVAL_MAX_RETRIES=2
# Optional, slower LLM-based semantic critique on top of the linters (advisory).
ADEPT_AGENT__LLM_JUDGE_ENABLED=false
# Extra SPL commands to forbid, on top of the built-in destructive set
# (comma-separated; blank = built-in default list only).
ADEPT_AGENT__SPL_DENYLIST=

# ---- Observability (optional) ---------------------------------------------
# Tracing needs the 'observability' extra (uv sync --extra observability). When
# enabled, spans are exported via OTLP/HTTP to <ENDPOINT>/v1/traces (point this
# at an OpenTelemetry Collector, Tempo, Jaeger, etc.). When disabled or the
# extra is absent, ADEPT degrades to no-op spans plus structured timing logs.
ADEPT_OTEL__ENABLED=false
ADEPT_OTEL__ENDPOINT=http://localhost:4318
ADEPT_OTEL__SERVICE_NAME=adept
